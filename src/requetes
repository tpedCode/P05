-- REQUETE 4
-- Quels sont les 5 codes postaux, 
-- enregistrant plus de 30 reviews, 
-- avec le pire review score moyen sur les 12 derniers mois ?

SELECT
    c.customer_zip_code_prefix,
    AVG(r.review_score) AS score_moyen,
    COUNT(r.review_id) AS nb_reviews
FROM order_reviews r
JOIN orders o ON r.order_id = o.order_id
JOIN customers c ON o.customer_id = c.customer_id
WHERE o.order_purchase_timestamp >= (
    SELECT DATE(MAX(order_purchase_timestamp), '-12 months')
    FROM orders
)
GROUP BY c.customer_zip_code_prefix
HAVING COUNT(r.review_id) > 30
ORDER BY score_moyen ASC
LIMIT 5;

-- REQUETE 3
-- Qui sont les nouveaux vendeurs (moins de 3 mois d'ancienneté) 
-- qui sont déjà très engagés avec la plateforme (ayant déjà vendu plus de 30 produits) ?

SELECT
    oi.seller_id,
    COUNT(DISTINCT oi.order_id) AS nb_ventes,
    COUNT(oi.product_id) AS nb_produits,
    SUM(oi.price) AS CA,
    MIN(o.order_purchase_timestamp) AS premiere_vente
FROM order_items oi
INNER JOIN orders o ON oi.order_id = o.order_id
GROUP BY oi.seller_id
HAVING nb_ventes > 30
    AND o.order_status = 'delivered'
    AND premiere_vente > (
       SELECT DATE(MAX(order_purchase_timestamp), '-3 months')
       FROM orders
   );
